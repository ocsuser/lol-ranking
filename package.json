{
  "name": "lol-esports-scraper",
  "version": "1.0.0",
  "description": "Scraper de stats joueurs LoL Esports depuis gol.gg",
  "type": "module",
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsc",
    "scrape": "tsx leagues/lck-cup-2026/scrape.ts && tsx leagues/lec-versus-2026/scrape.ts",
    "predev": "node scripts/prompt-scrape.js",
    "dev": "npm run dev --prefix frontend"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "cheerio": "^1.2.0",
    "commander": "^12.0.0",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.0.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0"
  }
}
